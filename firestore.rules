rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document (by UID in match)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to check if user owns the data (by UID in resource field)
    function ownsData(resource) {
      return isAuthenticated() && resource != null && resource.data.userId == request.auth.uid;
    }
    
    // User settings
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Transactions
    match /transactions/{transactionId} {
      allow read: if ownsData(resource);
      allow create: if ownsData(request.resource);
      allow update: if ownsData(resource) && request.resource.data.userId == resource.data.userId;
      allow delete: if ownsData(resource);
    }
    
    // Assets
    match /assets/{assetId} {
      allow read: if ownsData(resource);
      allow create: if ownsData(request.resource);
      allow update: if ownsData(resource) && request.resource.data.userId == resource.data.userId;
      allow delete: if ownsData(resource);
    }
    
    // Liabilities
    match /liabilities/{liabilityId} {
      allow read: if ownsData(resource);
      allow create: if ownsData(request.resource);
      allow update: if ownsData(resource) && request.resource.data.userId == resource.data.userId;
      allow delete: if ownsData(resource);
    }
    
    // Monthly Snapshots
    match /monthlySnapshots/{snapshotId} {
      allow read: if ownsData(resource);
      allow create: if ownsData(request.resource);
      allow update: if ownsData(resource) && request.resource.data.userId == resource.data.userId;
      allow delete: if ownsData(resource);
    }

    // Recurring Expenses
    match /recurringExpenses/{recurringId} {
      allow read: if ownsData(resource);
      allow create: if ownsData(request.resource);
      allow update: if ownsData(resource) && request.resource.data.userId == resource.data.userId;
      allow delete: if ownsData(resource);
    }
  }
}
